#!/bin/bash
# Debounced wrapper around omarchy-powerprofiles-set.
# The ROG Flow Z13 generates spurious power_supply change events from both
# AC0 (proprietary charger) and ucsi-source-psy-USBC000:001 (USB-C UCSI
# controller). Without debouncing, each event triggers a full profile set →
# asusd fan curve rewrite → momentary fan stop.
#
# This wrapper sleeps briefly to let events settle, then calls the original.
# systemd-run's unit name (omarchy-power-profile) ensures only one instance
# runs at a time — concurrent events are naturally deduplicated.

sleep 3
exec "__HOME__/.local/share/omarchy/bin/omarchy-powerprofiles-set" "$@"
